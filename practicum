# On-demand situational awareness
situation() {
    echo ""
    echo -e "\${C_CYAN}  📍 Current Situation\${C_RESET}"
    echo -e "  \${C_DIM}Directory: \$(pwd)\${C_RESET}"
    echo -e "  \${C_DIM}Files: \$(ls -1 2>/dev/null | wc -l)\${C_RESET}"
    echo -e "  \${C_DIM}Disk used here: \$(du -sh . 2>/dev/null | cut -f1)\${C_RESET}"
    echo ""
}

# Block practicum from inside lab
practicum() {
    echo -e "\${C_YELLOW}  ⚠️  Type 'exit' to leave Lab first, then run practicum.\${C_RESET}"
}

echo ""
echo -e "\${C_PURPLE}=========================================\${C_RESET}"
echo -e "\${C_PURPLE}  🔬 LAB MODE — Safe Sandbox\${C_RESET}"
echo -e "\${C_PURPLE}=========================================\${C_RESET}"
echo ""
echo -e "  \${C_WHITE}All commands affect only the sandbox.\${C_RESET}"
echo -e "  \${C_CYAN}Sandbox: ~/.practicum/sandbox/\${C_RESET}"
echo -e "  \${C_DIM}Type 'situation' for system awareness.\${C_RESET}"
echo -e "  \${C_GREEN}Type 'exit' to leave Lab mode.\${C_RESET}"
echo ""
cd "$HOME/.practicum/sandbox"
LABRC
    
    exec bash --rcfile "$lab_rc" -i
}

