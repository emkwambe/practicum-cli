#!/bin/bash
# Practicum CLI — Intent. Context. Action. Result.
# Version: 0.2.0

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source all libraries
source "$SCRIPT_DIR/lib/colors.sh"
source "$SCRIPT_DIR/lib/state.sh"
source "$SCRIPT_DIR/lib/lessons.sh"
source "$SCRIPT_DIR/lib/quiz_engine.sh"
source "$SCRIPT_DIR/lib/modes.sh"
source "$SCRIPT_DIR/lib/sandbox.sh"
source "$SCRIPT_DIR/lib/wrappers.sh"

# Initialize state on every run
init_state

# --- Command Implementations ---

show_help() {
    cat << 'EOF'
Practicum CLI — Linux terminal courses
Intent. Context. Action. Result.

Usage: practicum <command>

Commands:
  start       Begin or resume a course
  status      Show your progress
  quiz        Take the current quiz
  wizard      Enter Wizard mode (guided lessons)
  lab         Enter Lab mode (safe sandbox)
  field       Enter Field mode (real system)
  snapshot    Save/restore lab state
  certificate Generate completion certificate
  activate    Activate a license key
  help        Show this help message

Navigation (available anytime):
  menu        Return to main menu
  back        Go back one step
  status      Show progress

Version: 0.2.0
EOF
}

cmd_status() {
    local mode
    mode=$(get_mode)
    local completed
    completed=$(count_completed)
    local unlocked
    unlocked=$(count_unlocked)
    local day1_score
    day1_score=$(get_score "day1_quiz")
    local day2_score
    day2_score=$(get_score "day2_quiz")
    local day3_score
    day3_score=$(get_score "day3_quiz")
    
    print_header "📊 Practicum CLI — Status"
    echo -e "  ${C_WHITE}Course:${C_RESET}    Linux Foundations for IT & DevOps"
    echo -e "  ${C_WHITE}Mode:${C_RESET}      ${C_CYAN}$mode${C_RESET}"
    echo -e "  ${C_WHITE}Completed:${C_RESET} ${C_GREEN}$completed lessons${C_RESET}"
    echo -e "  ${C_WHITE}Unlocked:${C_RESET}  $unlocked lessons"
    echo ""
    if [ -n "$day1_score" ]; then
        echo -e "  Day 1 Quiz: ${C_GREEN}✅ $day1_score${C_RESET}"
    else
        echo -e "  Day 1 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    if [ -n "$day2_score" ]; then
        echo -e "  Day 2 Quiz: ${C_GREEN}✅ $day2_score${C_RESET}"
    else
        echo -e "  Day 2 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    if [ -n "$day3_score" ]; then
        echo -e "  Day 3 Quiz: ${C_GREEN}✅ $day3_score${C_RESET}"
    else
        echo -e "  Day 3 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    local day4_score
    day4_score=$(get_score "day4_quiz")
    if [ -n "$day4_score" ]; then
        echo -e "  Day 4 Quiz: ${C_GREEN}✅ $day4_score${C_RESET}"
    else
        echo -e "  Day 4 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    local day5_score
    day5_score=$(get_score "day5_quiz")
    if [ -n "$day5_score" ]; then
        echo -e "  Day 5 Quiz: ${C_GREEN}✅ $day5_score${C_RESET}"
    else
        echo -e "  Day 5 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    local capstone_score
    capstone_score=$(get_score "capstone")
    if [ -n "$capstone_score" ]; then
        echo -e "  Capstone:   ${C_GREEN}🏆 $capstone_score${C_RESET}"
    fi
    local day6_score
    day6_score=$(get_score "day6_quiz")
    if [ -n "$day6_score" ]; then
        echo -e "  Day 6 Quiz: ${C_GREEN}✅ $day6_score${C_RESET}"
    else
        echo -e "  Day 6 Quiz: ${C_DIM}not taken${C_RESET}"
    fi
    echo ""
    echo -e "  ${C_PURPLE}Unlocked lessons:${C_RESET}"
    if [ -f "$UNLOCKED_FILE" ]; then
        while IFS= read -r lesson; do
            if is_completed "$lesson"; then
                print_completed "$lesson"
            else
                print_unlocked "$lesson"
            fi
        done < "$UNLOCKED_FILE"
    fi
    echo ""
    echo -e "${C_PURPLE}=========================================${C_RESET}"
    echo ""
}

cmd_start() {
    print_header "Practicum CLI — Linux Foundations"
    echo -e "  ${C_DIM}Intent. Context. Action. Result.${C_RESET}"
    echo ""
    echo -e "  ${C_PURPLE}Course Days:${C_RESET}"
    echo ""
    print_menu_item "1" "Day 1 — Navigation & Files"
    print_menu_item "2" "Day 2 — Text Processing & Pipes"
    print_menu_item "3" "Day 3 — Scripting Basics"
    print_menu_item "4" "Day 4 — Process & Environment"
    print_menu_item "5" "Day 5 — Final Assessment"
    print_menu_item "6" "Day 6 — Permissions & Security"
    echo ""
    echo -e "  ${C_PURPLE}Tools:${C_RESET}"
    echo ""
    print_menu_item "p" "View progress"
    print_menu_item "q" "Take quiz"
    print_menu_item "c" "Generate certificate"
    print_menu_item "x" "🏋️ Linux Challenges"
    print_menu_item "0" "Exit"
    print_prompt
    read -r choice || return 0
    
    case "$choice" in
        1) cmd_day1_menu ;;
        2) cmd_day2_menu ;;
        3) cmd_day3_menu ;;
        4) cmd_day4_menu ;;
        5) cmd_day5_menu ;;
        6) cmd_day6_menu ;;
        p|P) cmd_status ;;
        q|Q) cmd_quiz_select ;;
        c|C) cmd_certificate ;;
        x|X) cmd_challenges ;;
        0) echo -e "  ${C_GREEN}Goodbye!${C_RESET}"; return 0 ;;
        *) echo -e "  ${C_RED}Invalid choice.${C_RESET}"; cmd_start ;;
    esac
}

cmd_day1_menu() {
    list_lessons "day1"
    printf "  Your choice: "
    read -r choice || return 0
    
    case "$choice" in
        [1-6])
            local lesson_file
            lesson_file=$(get_lesson_file_by_number "day1" "$choice")
            if [ -n "$lesson_file" ]; then
                local cmd
                cmd=$(get_lesson_command "$lesson_file")
                if is_unlocked "$cmd" || [ "$choice" -le 3 ]; then
                    load_lesson "day1" "$lesson_file"
                    add_completed "$cmd"
                    # Unlock next lesson
                    case "$cmd" in
                        pwd) unlock_lesson "ls" ;;
                        ls)  unlock_lesson "cd" ;;
                        cd)  unlock_lesson "mkdir" ;;
                        mkdir) unlock_lesson "touch" ;;
                        touch) unlock_lesson "rm" ;;
                    esac
                    echo "  ✅ Lesson '$cmd' completed!"
                    show_encouragement "day1"
                    echo "  [1] Next lesson"
                    echo "  [2] Repeat this lesson"
                    echo "  [7] Take Day 1 quiz"
                    echo "  [9] Back to Day 1 menu"
                    echo "  [0] Main menu"
                    echo ""
                    printf "  Your choice: "
                    read -r next || return 0
                    case "$next" in
                        1) cmd_day1_menu ;;
                        2) load_lesson "day1" "$lesson_file" ;;
                        7) cmd_quiz ;;
                        9) cmd_day1_menu ;;
                        0) cmd_start ;;
                    esac
                else
                    echo "  🔒 This lesson is locked. Complete previous lessons first."
                    cmd_day1_menu
                fi
            else
                echo "  Invalid lesson number."
                cmd_day1_menu
            fi
            ;;
        9)
            cmd_start
            ;;
        0)
            return 0
            ;;
        *)
            echo "  Invalid choice."
            cmd_day1_menu
            ;;
    esac
}

