    export PS1="🔬 [LAB] \w\$ "
    exec bash --norc --noprofile -i
}

cmd_field() {
    enter_mode "FIELD"
    echo "  Type 'exit' to leave FIELD mode."
    echo ""
    export PS1="🌍 [FIELD] \w\$ "
    exec bash --norc --noprofile -i
}

cmd_snapshot() {
    case "$2" in
        save)
            snapshot_save "$3"
            ;;
        restore)
            snapshot_restore "$3"
            ;;
        list)
            snapshot_list
            ;;
        *)
            echo "Usage: practicum snapshot {save|restore|list} [name]"
            ;;
    esac
}

# --- Main Entry Point ---
case "$1" in
    start)
        cmd_start
        ;;
    status)
        cmd_status
        ;;
    quiz)
        cmd_quiz
        ;;
    wizard)
        cmd_wizard
        ;;
    lab)
        cmd_lab
        ;;
    field)
        cmd_field
        ;;
    snapshot)
        cmd_snapshot "$@"
        ;;
    activate)
        echo "License activation not yet implemented."
        echo "Contact: support@practicum-cli.dev"
        ;;
    certificate|cert)
        cmd_certificate
        ;;
    final)
        cmd_final
        ;;
    --help|-h|help)
        show_help
        ;;
    *)
        show_help
        ;;
esac