cmd_quiz_select() {
    echo ""
    echo "  Select a quiz:"
    echo ""
    echo "  [1] Day 1 — Navigation & Files"
    echo "  [2] Day 2 — Text Processing & Pipes"
    echo "  [3] Day 3 — Scripting Basics"
    echo "  [9] Back to main menu"
    echo ""
    printf "  Your choice: "
    read -r qchoice || return 0
    case "$qchoice" in
        1) cmd_quiz ;;
        2) cmd_quiz_day2 ;;
        3) cmd_quiz_day3 ;;
        9) cmd_start ;;
        *) echo "  Invalid choice." ;;
    esac
}

cmd_quiz_day3() {
    detect_course_dir
    local quiz_file="$COURSE_DIR/day3/quiz3.txt"
    
    if run_quiz "$quiz_file"; then
        save_score "day3_quiz" "passed"
        echo ""
        echo "========================================="
        echo "  🎓 Day 3 Quiz — PASSED!"
        echo ""
        echo "  You now know the building blocks of bash scripting."
        echo "  Try 'practicum certificate' to generate your certificate!"
        echo "========================================="
        echo ""
    else
        echo ""
        echo "  📖 Review the Day 3 lessons and try again."
        echo "  Focus on exit codes and conditionals."
        echo ""
    fi
}

cmd_certificate() {
    local day1_score
    day1_score=$(get_score "day1_quiz")
    
    if [ "$day1_score" != "passed" ]; then
        echo ""
        echo "  ❌ You must pass the Day 1 quiz to earn a certificate."
        echo "  Type 'practicum start' and choose [7] Take quiz."
        echo ""
        return 1
    fi
    
    local day2_score
    day2_score=$(get_score "day2_quiz")
    local day3_score
    day3_score=$(get_score "day3_quiz")
    
    local days_passed="Day 1: Navigation & Files"
    [ "$day2_score" = "passed" ] && days_passed="$days_passed
    Day 2: Text Processing & Pipes"
    [ "$day3_score" = "passed" ] && days_passed="$days_passed
    Day 3: Scripting Basics"
    
    local completed
    completed=$(count_completed)
    local cert_date
    cert_date=$(date '+%B %d, %Y')
    local cert_hash
    cert_hash=$(echo -n "practicum:${USER}:$(date +%Y-%m-%d):${completed}" | sha256sum | cut -c1-12)
    
    echo ""
    echo "  ╔════════════════════════════════════════════════════════╗"
    echo "  ║                                                        ║"
    echo "  ║          🎓  PRACTICUM CLI CERTIFICATE  🎓             ║"
    echo "  ║                                                        ║"
    echo "  ║   This certifies that                                  ║"
    echo "  ║                                                        ║"
    echo "  ║   Student: $USER"
    echo "  ║                                                        ║"
    echo "  ║   has successfully completed:                          ║"
    echo "  ║                                                        ║"
    echo "  ║   ✅ Linux Foundations for IT & DevOps                 ║"
    echo "  ║      $days_passed"
    echo "  ║                                                        ║"
    echo "  ║   Lessons completed: $completed                        "
    echo "  ║   Date: $cert_date                                     "
    echo "  ║   Certificate ID: $cert_hash                           "
    echo "  ║                                                        ║"
    echo "  ║   Practicum CLI — Intent. Context. Action. Result.     ║"
    echo "  ║                                                        ║"
    echo "  ╚════════════════════════════════════════════════════════╝"
    echo ""
}

cmd_wizard() {
    enter_mode "WIZARD"
    echo "  Starting guided lesson flow..."
    echo ""
    cmd_start
}

cmd_lab() {
    enter_mode "LAB"
    init_sandbox
    echo "  Sandbox initialized at: ~/.practicum/sandbox/"
    echo "  Type 'exit' to leave LAB mode."
    echo ""
    cd "$SANDBOX_DIR" || true
    export PS1="🔬 [LAB] \w\$ "
    exec bash --norc --noprofile -i
}

cmd_field() {
    enter_mode "FIELD"
    echo "  Type 'exit' to leave FIELD mode."
    echo ""
    export PS1="🌍 [FIELD] \w\$ "
    exec bash --norc --noprofile -i
}

cmd_snapshot() {
    case "$2" in
        save)
            snapshot_save "$3"
            ;;
        restore)
            snapshot_restore "$3"
            ;;
        list)
            snapshot_list
            ;;
        *)
            echo "Usage: practicum snapshot {save|restore|list} [name]"
            ;;
    esac
}

# --- Main Entry Point ---
case "$1" in
    start)
        cmd_start
        ;;
    status)
        cmd_status
        ;;
    quiz)
        cmd_quiz
        ;;
    wizard)
        cmd_wizard
        ;;
    lab)
        cmd_lab
        ;;
    field)
        cmd_field
        ;;
    snapshot)
        cmd_snapshot "$@"
        ;;
    activate)
        echo "License activation not yet implemented."
        echo "Contact: support@practicum-cli.dev"
        ;;
    certificate|cert)
        cmd_certificate
        ;;
    --help|-h|help)
        show_help
        ;;
    *)
        show_help
        ;;
esac