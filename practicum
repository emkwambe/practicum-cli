cmd_certificate() {
    local day1_score
    day1_score=$(get_score "day1_quiz")
    
    if [ "$day1_score" != "passed" ]; then
        echo ""
        echo "  ❌ You must pass the Day 1 quiz to earn a certificate."
        echo "  Type 'practicum start' and choose [7] Take quiz."
        echo ""
        return 1
    fi
    
    local day2_score
    day2_score=$(get_score "day2_quiz")
    local day3_score
    day3_score=$(get_score "day3_quiz")
    
    local days_passed="Day 1: Navigation & Files"
    [ "$day2_score" = "passed" ] && days_passed="$days_passed
    Day 2: Text Processing & Pipes"
    [ "$day3_score" = "passed" ] && days_passed="$days_passed
    Day 3: Scripting Basics"
    
    local completed
    completed=$(count_completed)
    local cert_date
    cert_date=$(date '+%B %d, %Y')
    local cert_hash
    cert_hash=$(echo -n "practicum:${USER}:$(date +%Y-%m-%d):${completed}" | sha256sum | cut -c1-12)
    
    echo ""
    echo "  ╔════════════════════════════════════════════════════════╗"
    echo "  ║                                                        ║"
    echo "  ║          🎓  PRACTICUM CLI CERTIFICATE  🎓             ║"
    echo "  ║                                                        ║"
    echo "  ║   This certifies that                                  ║"
    echo "  ║                                                        ║"
    echo "  ║   Student: $USER"
    echo "  ║                                                        ║"
    echo "  ║   has successfully completed:                          ║"
    echo "  ║                                                        ║"
    echo "  ║   ✅ Linux Foundations for IT & DevOps                 ║"
    echo "  ║      $days_passed"
    echo "  ║                                                        ║"
    echo "  ║   Lessons completed: $completed                        "
    echo "  ║   Date: $cert_date                                     "
    echo "  ║   Certificate ID: $cert_hash                           "
    echo "  ║                                                        ║"
    echo "  ║   Practicum CLI — Intent. Context. Action. Result.     ║"
    echo "  ║                                                        ║"
    echo "  ╚════════════════════════════════════════════════════════╝"
    echo ""
}

