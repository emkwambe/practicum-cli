cmd_start() {
    # Show career overview on first run
    local first_run_flag="$HOME/.practicum/first_run_done"
    if [ ! -f "$first_run_flag" ]; then
        detect_course_dir
        local overview="$COURSE_DIR/career_overview.txt"
        if [ -f "$overview" ]; then
            print_header "Welcome to Practicum CLI"
            echo ""
            while IFS= read -r line; do
                case "$line" in
                    "## "*)
                        echo -e "  ${C_PURPLE}${line#\#\# }${C_RESET}"
                        ;;
                    "  ✅"*)
                        echo -e "  ${C_GREEN}${line#  }${C_RESET}"
                        ;;
                    "  -"*|"     -"*)
                        echo -e "  ${C_DIM}${line}${C_RESET}"
                        ;;
                    "  Day"*)
                        echo -e "  ${C_CYAN}${line#  }${C_RESET}"
                        ;;
                    "  -"*|"#"*)
                        : # skip markdown headers and comments
                        ;;
                    *)
                        echo -e "  ${C_WHITE}${line}${C_RESET}"
                        ;;
                esac
            done < "$overview"
            echo ""
            printf "  ${C_CYAN}Press Enter to continue...${C_RESET}"
            read -r
            touch "$first_run_flag"
        fi
    fi
    
    local course_name
    course_name=$(get_course_name)
    print_header "Practicum CLI — $course_name"
    echo -e "  ${C_DIM}Intent. Context. Action. Result.${C_RESET}"
    echo ""
    echo -e "  ${C_PURPLE}Foundation:${C_RESET}"
    print_menu_item "1" "$(get_day_title 1)"
    print_menu_item "2" "$(get_day_title 2)"
    print_menu_item "3" "$(get_day_title 3)"
    print_menu_item "4" "$(get_day_title 4)"
    print_menu_item "5" "$(get_day_title 5)"
    echo ""
    echo -e "  ${C_PURPLE}Advanced:${C_RESET}"
    print_menu_item "6" "$(get_day_title 6)"
    print_menu_item "7" "$(get_day_title 7)"
    print_menu_item "8" "$(get_day_title 8)"
    print_menu_item "9" "$(get_day_title 9)"
    echo ""
    echo -e "  ${C_PURPLE}Capstone:${C_RESET}"
    print_menu_item "10" "$(get_day_title 10)"
    echo ""
    echo -e "  ${C_PURPLE}Tools:${C_RESET}"
    print_menu_item "p" "View progress"
    print_menu_item "q" "Take quiz"
    print_menu_item "c" "Generate certificate"
    print_menu_item "x" "🏋️ Challenges"
    print_menu_item "s" "🏢 Work Scenarios"
    print_menu_item "m" "🎯 Skill Mastery"
    print_menu_item "k" "📚 Switch course"
    print_menu_item "d" "🩺 IT Clinic (diagnose)"
    print_menu_item "0" "Exit"
    print_prompt
    read -r choice || return 0
    
    case "$choice" in
        1) cmd_day1_menu ;;
        2) cmd_day2_menu ;;
        3) cmd_day3_menu ;;
        4) if can_access_day "day4"; then cmd_day4_menu; else show_upgrade_prompt; cmd_start; fi ;;
        5) if can_access_day "day5"; then cmd_day5_menu; else show_upgrade_prompt; cmd_start; fi ;;
        6) if can_access_day "day6"; then cmd_day6_menu; else show_upgrade_prompt; cmd_start; fi ;;
        7) if can_access_day "day7"; then cmd_day7_menu; else show_upgrade_prompt; cmd_start; fi ;;
        8) if can_access_day "day8"; then cmd_day8_menu; else show_upgrade_prompt; cmd_start; fi ;;
        9) if can_access_day "day9"; then cmd_day9_menu; else show_upgrade_prompt; cmd_start; fi ;;
        10) if can_access_day "day10"; then cmd_day10_menu; else show_upgrade_prompt; cmd_start; fi ;;
        p|P) cmd_status ;;
        q|Q) cmd_quiz_select ;;
        c|C) cmd_certificate ;;
        x|X) cmd_challenges ;;
        s|S) cmd_scenarios; cmd_start ;;
        m|M) show_mastery_dashboard; cmd_start ;;
        k|K) cmd_course_switch; cmd_start ;;
        d|D) cmd_diagnose; cmd_start ;;
        0) echo -e "  ${C_GREEN}Goodbye!${C_RESET}"; return 0 ;;
        *) echo -e "  ${C_RED}Invalid choice.${C_RESET}"; cmd_start ;;
    esac
}

cmd_course_switch() {
    print_header "Switch Course"
    echo ""
    echo -e "  ${C_WHITE}Available courses:${C_RESET}"
    echo ""

    local current
    current=$(get_active_course)

    local i=1
    local courses=()
    while IFS= read -r course; do
        courses+=("$course")
        local name
        name=$(get_course_name "$course")
        if [ "$course" = "$current" ]; then
            echo -e "  ${C_GREEN}[$i] $name ← currently active${C_RESET}"
        else
            echo -e "  ${C_CYAN}[$i] $name${C_RESET}"
        fi
        i=$((i + 1))
    done < <(list_available_courses)

    echo ""
    print_menu_item "0" "Cancel"
    print_prompt
    read -r choice || return 0

    if [ "$choice" = "0" ]; then
        return 0
    fi

    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#courses[@]}" ]; then
        local selected="${courses[$((choice - 1))]}"
        set_active_course "$selected"
        # Reset first-run flag so career overview shows for new course
        rm -f "$HOME/.practicum/first_run_done"
        local name
        name=$(get_course_name "$selected")
        echo ""
        echo -e "  ${C_GREEN}✅ Switched to: $name${C_RESET}"
        echo -e "  ${C_DIM}   Restart with: practicum start${C_RESET}"
        echo ""
    else
        echo -e "  ${C_RED}Invalid choice.${C_RESET}"
    fi
}

# --- Apprenticeship-Aware Lesson Display ---
# Wraps lesson with situational awareness (WIZARD), mastery tracking (all modes)
show_lesson_with_context() {
    local day="$1"
    local lesson_file="$2"
    local cmd="$3"
    local mode
    mode=$(get_mode 2>/dev/null || echo "WIZARD")
    
    # WIZARD mode: show situation before lesson
    if [ "$mode" = "WIZARD" ]; then
        show_situation "$cmd"
    fi
    
    # Show the lesson
    load_lesson "$day" "$lesson_file"
    
    # WIZARD mode: show senior tip after lesson
    if [ "$mode" = "WIZARD" ]; then
        senior_tip "$cmd"
    fi
    
    # All modes: record mastery
    record_skill_use "$cmd" "lesson"
}

cmd_day1_menu() {
    list_lessons "day1"
    printf "  Your choice: "
    read -r choice || return 0
    
    case "$choice" in
        [1-6])
            local lesson_file
            lesson_file=$(get_lesson_file_by_number "day1" "$choice")
            if [ -n "$lesson_file" ]; then
                local cmd
                cmd=$(get_lesson_command "$lesson_file")
                if is_unlocked "$cmd" || [ "$choice" -le 3 ]; then
                    show_lesson_with_context "day1" "$lesson_file" "$cmd"
                    add_completed "$cmd"
                    # Unlock next lesson
                    case "$cmd" in
                        pwd) unlock_lesson "ls" ;;
                        ls)  unlock_lesson "cd" ;;
                        cd)  unlock_lesson "mkdir" ;;
                        mkdir) unlock_lesson "touch" ;;
                        touch) unlock_lesson "rm" ;;
                    esac
                    unlock_next_from_chain "$cmd"
                    echo "  ✅ Lesson '$cmd' completed!"
                    show_encouragement "day1"
                    echo "  [1] Next lesson"
                    echo "  [2] Repeat this lesson"
                    echo "  [7] Take Day 1 quiz"
                    echo "  [9] Back to Day 1 menu"
                    echo "  [0] Main menu"
                    echo ""
                    printf "  Your choice: "
                    read -r next || return 0
                    case "$next" in
                        1) cmd_day1_menu ;;
                        2) load_lesson "day1" "$lesson_file" ;;
                        7) cmd_quiz ;;
                        9) cmd_day1_menu ;;
                        0) cmd_start ;;
                    esac
                else
                    echo "  🔒 This lesson is locked. Complete previous lessons first."
                    cmd_day1_menu
                fi
            else
                echo "  Invalid lesson number."
                cmd_day1_menu
            fi
            ;;
        9)
            cmd_start
            ;;
        0)
            return 0
            ;;
        *)
            echo "  Invalid choice."
            cmd_day1_menu
            ;;
    esac
}

